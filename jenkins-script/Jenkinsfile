pipeline {
    agent any

    environment {
        SERVICE_NAME = 'authentication-service'
        DOCKERHUB_CREDENTIALS = credentials('docker-creds')
        DOCKERHUB_USERNAME = 'thenoobgrammer'
        REPO_BASE = 'pickside-service'
        TAG = 'latest'
        VAULT_ADDRESS = credentials('vault-address')
        VAULT_TOKEN = credentials('vault-token')
        PLATFORM = 'linux/amd64'
        EC2_HOST = 'ec2-34-225-177-141.compute-1.amazonaws.com'
        SSH_KEY_CREDENTIALS = 'aws-ec2-ssh-key'
    }

    stages {
        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-creds', usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh 'echo $DOCKER_PASSWORD | docker login --username $DOCKER_USERNAME --password-stdin'
                }
            }
        }
        stage('Build and Push') {
            steps {
                script {
                    dir("../deploy-${SERVICE_NAME}") {
                        sh """
                            export DOCKER_CLI_EXPERIMENTAL=enabled
                            docker build -t ${DOCKERHUB_USERNAME}/${REPO_BASE}:${SERVICE_NAME}-${TAG} .
                            docker push ${DOCKERHUB_USERNAME}/${REPO_BASE}:${SERVICE_NAME}-${TAG}
                        """
                    }
                }
            }
        }
        stage('Cleanup') {
            steps {
                script {
                    sh "docker rmi ${DOCKERHUB_USERNAME}/${REPO_BASE}:${SERVICE_NAME}-${TAG} || true"
                }
            }
        }
        stage('Restarting service') {
            steps {
                script {
                    sshagent([SSH_KEY_CREDENTIALS]) {
                        sh """
                            echo "Checking loaded SSH keys..."
                            ssh-add -L
                            echo "Connecting to server..."
                            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} << EOF
                                set -e
                                docker ps -q --filter 'name=!vault' | xargs -r docker stop

                                echo 'Pulling latest images for ${SERVICE_NAME}...';
                                docker pull ${DOCKERHUB_USERNAME}/${REPO_BASE}:${SERVICE_NAME}-latest

                                echo 'Removing old containers...';
                                docker rm -f ${SERVICE_NAME}-prod || true

                                echo 'Running new containers...';
                                docker run -d -e VAULT_TOKEN=${VAULT_TOKEN} -e VAULT_ADDRESS=${VAULT_ADDRESS} --name ${SERVICE_NAME}-prod -p 8083:8083 ${DOCKERHUB_USERNAME}/${REPO_BASE}:${SERVICE_NAME}-latest
                            EOF
                        """
                    }
                }
            }
        }
    }
}